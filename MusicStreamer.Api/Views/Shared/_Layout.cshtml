<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MusicStreamer</title>
    <style>
        :root {
            color-scheme: dark;
            --bg: #0b0f14;
            --surface: #121820;
            --surface-2: #171f29;
            --border: #26303c;
            --text: #eef2f6;
            --muted: #9aa7b4;
            --accent: #1db954;
            --accent-2: #2a3644;
            --danger: #e05a67;
        }

        * { box-sizing: border-box; }
        body {
            margin: 0;
            font-family: Inter, Arial, sans-serif;
            background: var(--bg);
            color: var(--text);
        }

        body.is-loading {
            cursor: progress;
        }

        a { color: inherit; text-decoration: none; }
        button, input, select {
            font: inherit;
        }

        button {
            min-height: 38px;
            padding: 8px 14px;
            border: 1px solid var(--accent);
            border-radius: 999px;
            background: var(--accent);
            color: #08110b;
            font-weight: 700;
            cursor: pointer;
        }

        button.secondary {
            background: transparent;
            color: var(--text);
            border-color: var(--border);
        }

        input, select {
            min-height: 42px;
            padding: 10px 12px;
            border-radius: 12px;
            border: 1px solid var(--border);
            background: var(--surface);
            color: var(--text);
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        th, td {
            text-align: left;
            padding: 10px 0;
            border-bottom: 1px solid var(--border);
            vertical-align: top;
        }

        .muted { color: var(--muted); }
        .error {
            color: #ff8a95;
            margin: 0;
        }
        .status {
            background: rgba(29, 185, 84, 0.12);
            border: 1px solid rgba(29, 185, 84, 0.25);
            color: #b8f5ce;
            padding: 12px 14px;
            border-radius: 14px;
        }

        .global-loading {
            position: fixed;
            inset: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            background: rgba(7, 10, 14, 0.62);
            backdrop-filter: blur(8px);
            z-index: 9999;
            opacity: 0;
            pointer-events: none;
            transition: opacity 140ms ease;
        }

        .global-loading.is-visible {
            opacity: 1;
            pointer-events: all;
        }

        .global-loading-card {
            display: inline-flex;
            align-items: center;
            gap: 14px;
            padding: 16px 18px;
            border-radius: 18px;
            border: 1px solid var(--border);
            background: rgba(18, 24, 32, 0.96);
            box-shadow: 0 18px 48px rgba(0, 0, 0, 0.35);
        }

        .spinner {
            width: 20px;
            height: 20px;
            border-radius: 50%;
            border: 3px solid rgba(255, 255, 255, 0.16);
            border-top-color: var(--accent);
            animation: spin 0.8s linear infinite;
        }

        @@keyframes spin {
            to {
                transform: rotate(360deg);
            }
        }

        .app-shell {
            display: grid;
            grid-template-columns: 260px minmax(0, 1fr);
            min-height: 100vh;
        }

        .sidebar {
            background: #090d12;
            border-right: 1px solid var(--border);
            padding: 20px 16px;
            display: grid;
            gap: 18px;
            align-content: start;
        }

        .brand {
            display: flex;
            align-items: center;
            gap: 10px;
            font-size: 1.05rem;
            font-weight: 800;
            letter-spacing: 0.2px;
        }

        .brand-mark {
            width: 32px;
            height: 32px;
            border-radius: 10px;
            background: linear-gradient(135deg, #1db954, #0f7a34);
        }

        .side-group {
            display: grid;
            gap: 8px;
        }

        .side-label {
            color: var(--muted);
            font-size: 0.78rem;
            text-transform: uppercase;
            letter-spacing: 0.08em;
        }

        .nav-list {
            display: grid;
            gap: 6px;
        }

        .nav-link {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px 12px;
            border-radius: 12px;
            color: var(--text);
            background: transparent;
        }

        .nav-link.active {
            background: var(--surface-2);
            border: 1px solid var(--border);
        }

        .nav-link:hover {
            background: var(--surface-2);
        }

        .sidebar-card {
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 14px;
            background: var(--surface);
        }

        .sidebar-card strong {
            display: block;
            margin-bottom: 6px;
        }

        .sidebar-card form {
            margin-top: 12px;
        }

        .content {
            min-width: 0;
            display: grid;
            grid-template-rows: auto 1fr;
        }

        .content-top {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 12px;
            padding: 16px 24px;
            border-bottom: 1px solid var(--border);
            background: rgba(11, 15, 20, 0.9);
            backdrop-filter: blur(10px);
            position: sticky;
            top: 0;
            z-index: 10;
        }

        .content-body {
            padding: 24px;
        }

        .player-shell {
            position: sticky;
            bottom: 16px;
            margin: 0 24px 24px;
            padding: 14px 16px;
            border: 1px solid var(--border);
            border-radius: 18px;
            background: rgba(18, 24, 32, 0.94);
            box-shadow: 0 16px 40px rgba(0, 0, 0, 0.32);
            display: grid;
            gap: 12px;
        }

        .player-shell.locked {
            filter: grayscale(1);
            opacity: 0.72;
        }

        .player-shell.locked .player-controls {
            pointer-events: none;
        }

        .player-top {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 12px;
            flex-wrap: wrap;
        }

        .player-track {
            display: grid;
            gap: 2px;
        }

        .player-title {
            font-weight: 700;
        }

        .player-controls {
            display: flex;
            align-items: center;
            gap: 10px;
            flex-wrap: wrap;
        }

        .player-button {
            min-width: 42px;
            width: 42px;
            height: 42px;
            padding: 0;
            border-radius: 50%;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            background: var(--surface-2);
            color: var(--text);
            border-color: var(--border);
        }

        .player-button.primary {
            background: var(--accent);
            color: #08110b;
            border-color: var(--accent);
        }

        .player-meta {
            display: grid;
            gap: 8px;
        }

        .player-progress {
            width: 100%;
            height: 6px;
            border-radius: 999px;
            background: #1c2530;
            overflow: hidden;
        }

        .player-progress > span {
            display: block;
            width: 38%;
            height: 100%;
            background: linear-gradient(90deg, var(--accent), #54d97f);
            border-radius: inherit;
        }

        .player-lock-overlay {
            display: grid;
            gap: 6px;
            padding: 12px;
            border-radius: 14px;
            background: rgba(7, 10, 14, 0.72);
            border: 1px dashed var(--border);
        }

        .auth-shell {
            width: min(460px, calc(100% - 32px));
            margin: 48px auto;
        }

        .auth-shell section {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 20px;
        }

        h1, h2, h3 { margin: 0 0 12px; }
        h1 { font-size: 1.8rem; }
        h2 { font-size: 1.15rem; }
        h3 { font-size: 0.98rem; }
        p, li, label { font-size: 0.95rem; }
        form { display: grid; gap: 10px; }

        .inline-form {
            display: flex;
            gap: 8px;
            align-items: center;
            flex-wrap: wrap;
        }

        .grid {
            display: grid;
            gap: 16px;
        }

        .grid.two {
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        }

        .panel {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 18px;
        }

        .summary-item {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 16px;
        }

        .summary-item strong {
            display: block;
            font-size: 1.4rem;
            margin-top: 6px;
        }

        .stack {
            display: grid;
            gap: 12px;
        }

        .item-list {
            display: grid;
            gap: 10px;
            margin: 0;
            padding: 0;
            list-style: none;
        }

        .item-row {
            display: flex;
            justify-content: space-between;
            gap: 12px;
            align-items: center;
            border-top: 1px solid var(--border);
            padding-top: 10px;
        }

        .item-row:first-child {
            border-top: 0;
            padding-top: 0;
        }

        .scroll-table {
            width: 100%;
            overflow-x: auto;
        }

        .chip {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 8px 12px;
            border-radius: 999px;
            background: var(--surface-2);
            color: var(--text);
            border: 1px solid var(--border);
        }

        @@media (max-width: 980px) {
            .app-shell {
                grid-template-columns: 1fr;
            }

            .sidebar {
                border-right: 0;
                border-bottom: 1px solid var(--border);
            }

            .content-top {
                position: static;
            }
        }
    </style>
</head>
<body>
@{
    var useShell = (ViewData["UseAppShell"] as bool?) == true;
    var hasActiveSubscription = (ViewData["HasActiveSubscription"] as bool?) == true;
    var currentPlanName = ViewData["CurrentPlanName"] as string ?? string.Empty;
}

<div id="global-loading" class="global-loading" hidden aria-hidden="true" aria-live="polite" aria-busy="true">
    <div class="global-loading-card" role="status">
        <span class="spinner" aria-hidden="true"></span>
        <span>Carregando...</span>
    </div>
</div>

@if (useShell)
{
    <div class="app-shell">
        <aside class="sidebar">
            @await Html.PartialAsync("_Sidebar", (object?)ViewData.Model)
        </aside>
        <section class="content">
            <div class="content-top">
                <div class="chip">@ViewData["Title"]</div>
                <div class="muted">@DateTimeOffset.Now:dd/MM/yyyy</div>
            </div>
            <div class="content-body">
                @RenderBody()
            </div>
        </section>
    </div>
}
else
{
    <main class="auth-shell">
        @RenderBody()
    </main>
}
@if (useShell)
{
    <div class="player-shell @(hasActiveSubscription ? string.Empty : "locked")" aria-label="Player">
        <div class="player-top">
            <div class="player-track">
                <span class="player-title">Player</span>
                <span class="muted">@(hasActiveSubscription ? "Pronto para uso" : "Assine um plano para liberar o player")</span>
            </div>
            <div class="chip">@(hasActiveSubscription ? $"Plano ativo: {currentPlanName}" : "Assinatura pendente")</div>
        </div>

        <div class="player-meta">
            <div class="player-progress" aria-hidden="true"><span></span></div>
            <div class="player-controls">
                <button type="button" class="player-button secondary" aria-label="Anterior">Prev</button>
                <button type="button" class="player-button primary" aria-label="Reproduzir">Play</button>
                <button type="button" class="player-button secondary" aria-label="Pausar">Pause</button>
                <button type="button" class="player-button secondary" aria-label="Proxima">Next</button>
                <button type="button" class="player-button secondary" aria-label="Repetir">Loop</button>
                <button type="button" class="player-button secondary" aria-label="Aleatorio">Mix</button>
                <span class="muted">@(hasActiveSubscription ? "00:42 / 03:12" : "Recurso indisponivel ate ativar a assinatura")</span>
            </div>
        </div>
        @if (!hasActiveSubscription)
        {
            <div class="player-lock-overlay">
                <strong>Player indisponivel</strong>
                <span class="muted">Escolha um plano e conclua a ativacao de R$50 para liberar a reproducao.</span>
            </div>
        }
    </div>
}
<script>
    (() => {
        const overlay = document.getElementById('global-loading');
        if (!overlay) {
            return;
        }

        const showLoading = () => {
            overlay.hidden = false;
            overlay.classList.add('is-visible');
            document.body.classList.add('is-loading');
        };

        const hideLoading = () => {
            overlay.classList.remove('is-visible');
            document.body.classList.remove('is-loading');
            window.setTimeout(() => {
                if (!overlay.classList.contains('is-visible')) {
                    overlay.hidden = true;
                }
            }, 150);
        };

        document.addEventListener('submit', event => {
            const form = event.target;
            if (!(form instanceof HTMLFormElement)) {
                return;
            }

            if (form.noValidate || form.checkValidity()) {
                showLoading();
            }
        }, true);

        document.addEventListener('click', event => {
            const target = event.target;
            if (!(target instanceof Element)) {
                return;
            }

            const link = target.closest('a[href]');
            if (link instanceof HTMLAnchorElement && link.target !== '_blank' && !link.hasAttribute('download')) {
                showLoading();
            }
        }, true);

        window.addEventListener('pageshow', hideLoading);
        window.addEventListener('beforeunload', showLoading);
    })();
</script>
</body>
</html>
