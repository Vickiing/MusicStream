@model PainelViewModel
@{
    ViewData["Title"] = "Catálogo";
}

<div class="grid two">
    <section class="panel">
        <div class="player-top" style="margin-bottom:12px;">
            <h2>Bandas</h2>
            <span class="muted">@Model.Artists.Count</span>
        </div>
        <div class="catalog-grid">
            @foreach (var artist in Model.Artists)
            {
                <a class="catalog-card" asp-action="Search" asp-route-term="@artist.Name">
                    <div class="catalog-card-top">
                        <div>
                            <strong>@artist.Name</strong>
                            <div class="muted">Abrir busca desta banda</div>
                        </div>
                        <span class="catalog-pill">Ver</span>
                    </div>
                </a>
            }
        </div>
    </section>

    <section class="panel">
        <div class="player-top" style="margin-bottom:12px;">
            <h2>Álbuns</h2>
            <span class="muted">@Model.Albums.Count</span>
        </div>
        <div class="catalog-grid">
            @foreach (var album in Model.Albums)
            {
                <a class="catalog-card" asp-action="Search" asp-route-term="@album.Title">
                    <div class="catalog-card-top">
                        <div>
                            <strong>@album.Title</strong>
                            <div class="muted">@album.ArtistName • @album.ReleaseYear</div>
                        </div>
                        <span class="catalog-pill">Álbum</span>
                    </div>
                </a>
            }
        </div>
    </section>
</div>

<section class="panel" style="margin-top:16px;">
    <div class="player-top" style="margin-bottom:12px;">
        <h2>Músicas</h2>
        <span class="muted">@Model.Tracks.Count</span>
    </div>
    <div class="catalog-grid">
        @foreach (var track in Model.Tracks)
        {
            <div class="catalog-card">
                <div class="catalog-card-top">
                    <div>
                        <strong>@track.Title</strong>
                        <div class="muted">@track.ArtistName • @track.AlbumTitle</div>
                    </div>
                    <span class="catalog-pill">@(track.DurationSeconds / 60)m</span>
                </div>
                <div class="catalog-card-actions">
                    <a class="chip" asp-action="Search" asp-route-term="@track.ArtistName">Abrir banda</a>
                    <a class="chip" asp-action="Search" asp-route-term="@track.Title">Buscar música</a>
                </div>
            </div>
        }
    </div>
</section>
