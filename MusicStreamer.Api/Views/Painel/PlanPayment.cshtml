@model PagamentoPlanoViewModel
@{
    ViewData["Title"] = "Pagamento";
    var paymentAmountText = Model.PaymentAmount.ToString("C");
    var monthlyPriceText = Model.MonthlyPrice.ToString("C");
}

<div id="payment-status" class="status" style="display:@(string.IsNullOrWhiteSpace(Model.StatusMessage) ? "none" : "block")">
    @Model.StatusMessage
</div>

<section class="panel" style="margin:16px 0;">
    <div class="chip">Pagamento de ativação</div>
    <h1 style="margin-top:10px;">Finalize a assinatura de @Model.PlanName</h1>
    <p class="muted" style="max-width: 760px;">
        O valor fixo de R$50 apenas simula a confirmação da compra. Ao concluir, a assinatura passa a valer
        imediatamente no layout e no player.
    </p>
</section>

<div class="grid two">
    <section class="panel">
        <h2>Resumo</h2>
        <div class="stack">
            <div class="summary-item">
                <span class="muted">Plano escolhido</span>
                <strong>@Model.PlanName</strong>
            </div>
            <div class="summary-item">
                <span class="muted">Mensalidade cadastrada</span>
                <strong>@monthlyPriceText</strong>
            </div>
            <div class="summary-item">
                <span class="muted">Valor da transação</span>
                <strong>@paymentAmountText</strong>
            </div>
        </div>
    </section>

    <section class="panel">
        <h2>Confirmar pagamento</h2>
        @if (!Model.IsUpgradeAllowed)
        {
            <div class="status">Voce ja possui um plano igual ou superior. Escolha uma opcao acima do plano atual.</div>
        }

        <form asp-action="ConfirmPlanPayment" method="post" data-ajax-submit="true" data-status-target="#payment-status">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="PlanId" />
            <input type="hidden" asp-for="PaymentAmount" value="50" />

            <label>Valor fixo</label>
            <input value="@paymentAmountText" disabled />

            @if (Model.IsUpgradeAllowed)
            {
                <button type="submit">Pagar R$50 e ativar plano</button>
            }
            else
            {
                <button type="submit" disabled>Plano indisponível</button>
            }
        </form>
    </section>
</div>
