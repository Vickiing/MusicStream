@model PainelViewModel
@{
    ViewData["Title"] = "Planos";
}

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="status">@Model.StatusMessage</div>
}

@if (Model.HasActiveSubscription)
{
    <div class="status" style="margin-top:16px;">
        Plano ativo: <strong>@Model.CurrentPlanName</strong>
    </div>
}

<section class="panel" style="margin-bottom:16px;">
    <div class="chip">Assinatura</div>
    <h1 style="margin-top:10px;">Escolha um plano para liberar as musicas</h1>
    <p class="muted" style="max-width: 760px;">
        Selecione uma opcao de assinatura e siga para a tela de pagamento. A confirmacao usa um valor fixo de R$50
        para ativar o acesso ao player.
    </p>
</section>

<section class="grid two">
    @foreach (var plan in Model.Plans)
    {
        <div class="panel">
            <div class="chip">Plano</div>
            <h2 style="margin-top:10px;">@plan.Name</h2>
            <div class="muted">Mensalidade: @plan.MonthlyPrice.ToString("C")</div>
            <div class="muted">Limite de transacao: @plan.MaxTransactionAmount.ToString("C")</div>
            <div class="muted">Acesso noturno: @(plan.AllowsNightTransactions ? "Liberado" : "Bloqueado")</div>

            <div class="stack" style="margin-top:14px;">
                <div class="summary-item">
                    <span class="muted">Experiencia do plano</span>
                    <strong>@(plan.AllowsNightTransactions ? "Uso completo, inclusive a noite" : "Uso essencial para a demonstracao")</strong>
                </div>

                <form asp-action="ChoosePlan" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="PlanId" value="@plan.Id" />
                    <button type="submit">Ir para pagamento</button>
                </form>
            </div>
        </div>
    }
</section>

<section class="panel" style="margin-top:16px;">
    <strong>Fluxo esperado</strong>
    <p class="muted" style="margin:8px 0 0;">1. Escolher o plano. 2. Confirmar o pagamento de R$50. 3. Liberar o player e continuar navegando.</p>
</section>
