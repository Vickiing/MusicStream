@model PainelViewModel
@{
    ViewData["Title"] = "Planos";
}

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="status">@Model.StatusMessage</div>
}

@if (Model.HasActiveSubscription)
{
    <div class="status" style="margin-top:16px;">
        Plano ativo: <strong>@Model.CurrentPlanName</strong>
    </div>
}

<section class="panel" style="margin:16px 0;">
    <div class="chip">Assinatura</div>
    <h1 style="margin-top:10px;">Escolha um plano para liberar as músicas</h1>
    <p class="muted" style="max-width: 760px;">
        Cada plano libera a experiência do player. A confirmação usa um pagamento fixo de R$50 para a demonstracao e
        atualiza a assinatura imediatamente.
    </p>
</section>

<section class="grid two">
    @foreach (var plan in Model.Plans)
    {
        var canChoose = !Model.HasActiveSubscription || plan.MonthlyPrice > Model.CurrentPlanMonthlyPrice;
        <div class="panel">
            <div class="player-top">
                <div>
                    <h2>@plan.Name</h2>
                    <div class="muted">@plan.MonthlyPrice.ToString("C") por mes</div>
                </div>
                @if (!canChoose && Model.HasActiveSubscription && plan.MonthlyPrice == Model.CurrentPlanMonthlyPrice)
                {
                    <span class="catalog-pill">Atual</span>
                }
            </div>

            <div class="stack" style="margin-top:14px;">
                <div class="muted">Limite de transação: @plan.MaxTransactionAmount.ToString("C")</div>
                <div class="muted">Acesso noturno: @(plan.AllowsNightTransactions ? "Liberado" : "Bloqueado")</div>
            </div>

            <form asp-action="ChoosePlan" method="post" style="margin-top:16px;">
                @Html.AntiForgeryToken()
                <input type="hidden" name="PlanId" value="@plan.Id" />
                @if (canChoose)
                {
                    <button type="submit">Escolher plano</button>
                }
                else
                {
                    <button type="submit" disabled>Plano indisponível</button>
                }
            </form>
        </div>
    }
</section>
