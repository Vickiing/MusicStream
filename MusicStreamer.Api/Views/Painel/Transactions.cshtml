@model PainelViewModel
@{
    ViewData["Title"] = "Transações";
}

<div id="transactions-status" class="status" style="display:@(string.IsNullOrWhiteSpace(Model.StatusMessage) ? "none" : "block")">
    @Model.StatusMessage
</div>

<section class="panel" style="margin-top:16px;">
    <h2>Concluir pagamento</h2>
    <p class="muted">O sistema usa o horário atual automaticamente. O usuário só informa o comerciante e o valor.</p>
    <form asp-action="AuthorizeTransaction" method="post" data-ajax-submit="true" data-status-target="#transactions-status">
        @Html.AntiForgeryToken()
        <select name="MerchantId">
            @foreach (var merchant in Model.Merchants)
            {
                <option value="@merchant.Id">@merchant.Name (@merchant.Category)</option>
            }
        </select>
        <input type="number" name="Amount" step="0.01" min="0.01" placeholder="Valor" />
        <button type="submit">Concluir transação</button>
    </form>
</section>
