@model DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<style>
    .dashboard {
        display: grid;
        gap: 16px;
    }

    .hero {
        display: flex;
        justify-content: space-between;
        gap: 20px;
        align-items: flex-start;
        padding: 20px;
    }

    .hero h1 {
        margin: 0 0 6px;
        font-size: 1.9rem;
    }

    .hero-meta {
        display: grid;
        gap: 8px;
    }

    .summary-grid,
    .panel-grid {
        display: grid;
        gap: 16px;
    }

    .summary-grid {
        grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    }

    .panel-grid {
        grid-template-columns: repeat(auto-fit, minmax(360px, 1fr));
    }

    .summary-item,
    .panel {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 16px;
    }

    .summary-item strong {
        display: block;
        font-size: 1.35rem;
        margin-top: 6px;
    }

    .panel h2 {
        margin: 0 0 12px;
    }

    .panel h3 {
        margin: 18px 0 10px;
        font-size: 1rem;
    }

    .stack {
        display: grid;
        gap: 12px;
    }

    .muted-block {
        color: var(--muted);
        font-size: 0.92rem;
    }

    .scroll-table {
        width: 100%;
        overflow-x: auto;
    }

    .item-list {
        display: grid;
        gap: 10px;
        margin: 0;
        padding: 0;
        list-style: none;
    }

    .item-row {
        display: flex;
        justify-content: space-between;
        gap: 12px;
        align-items: center;
        border-top: 1px solid var(--border);
        padding-top: 10px;
    }

    .item-row:first-child {
        border-top: 0;
        padding-top: 0;
    }

    .inline-form {
        display: flex;
        gap: 8px;
        align-items: center;
        flex-wrap: wrap;
    }
</style>

<div class="dashboard">
    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="status">@Model.StatusMessage</div>
    }

    <section class="hero">
        <div class="hero-meta">
            <div>
                <h1>@Model.DisplayName</h1>
                <div class="muted">@Model.Email</div>
            </div>
        </div>
        <form asp-controller="AccountMvc" asp-action="Logout" method="post">
            @Html.AntiForgeryToken()
            <button type="submit" class="secondary">Sair</button>
        </form>
    </section>

    <section class="summary-grid">
        <div class="summary-item"><span class="muted">Bandas</span><strong>@Model.Artists.Count</strong></div>
        <div class="summary-item"><span class="muted">Albuns</span><strong>@Model.Albums.Count</strong></div>
        <div class="summary-item"><span class="muted">Musicas</span><strong>@Model.Tracks.Count</strong></div>
        <div class="summary-item"><span class="muted">Playlists</span><strong>@Model.Playlists.Count</strong></div>
        <div class="summary-item"><span class="muted">Planos</span><strong>@Model.Plans.Count</strong></div>
        <div class="summary-item"><span class="muted">Transacoes</span><strong>@Model.Transactions.Count</strong></div>
    </section>

    <div class="panel-grid">
        <section class="panel">
            <h2>Plano e playlists</h2>
            <div class="stack">
                <div>
                    <h3>Plano</h3>
                    <div class="scroll-table">
                        <table>
                            <thead>
                                <tr><th>Plano</th><th>Preco</th><th>Limite</th><th></th></tr>
                            </thead>
                            <tbody>
                            @foreach (var plan in Model.Plans)
                            {
                                <tr>
                                    <td>@plan.Name</td>
                                    <td>@plan.MonthlyPrice.ToString("C")</td>
                                    <td>@plan.MaxTransactionAmount.ToString("C")</td>
                                    <td>
                                        <form asp-action="ChoosePlan" method="post" class="inline-form">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="PlanId" value="@plan.Id" />
                                            <button type="submit">Selecionar</button>
                                        </form>
                                    </td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>
                </div>

                <div>
                    <h3>Nova playlist</h3>
                    <form asp-action="CreatePlaylist" method="post" class="stack">
                        @Html.AntiForgeryToken()
                        <input type="text" name="Name" placeholder="Nome da playlist" />
                        <button type="submit">Criar</button>
                    </form>
                </div>

                <div>
                    <h3>Playlists</h3>
                    @if (!Model.Playlists.Any())
                    {
                        <p class="muted-block">Sem playlists.</p>
                    }
                    else
                    {
                        <div class="stack">
                            @foreach (var playlist in Model.Playlists)
                            {
                                <div style="border-top:1px solid var(--border); padding-top:12px;">
                                    <strong>@playlist.Name</strong>
                                    <div class="muted-block">@playlist.Tracks.Count musicas</div>

                                    <form asp-action="AddTrack" method="post" class="inline-form" style="margin-top:10px;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="PlaylistId" value="@playlist.Id" />
                                        <select name="TrackId">
                                            @foreach (var track in Model.Tracks)
                                            {
                                                <option value="@track.Id">@track.Title - @track.ArtistName</option>
                                            }
                                        </select>
                                        <button type="submit">Adicionar</button>
                                    </form>

                                    @if (playlist.Tracks.Any())
                                    {
                                        <ul class="item-list" style="margin-top:12px;">
                                            @foreach (var track in playlist.Tracks)
                                            {
                                                <li>@track.Title - @track.ArtistName</li>
                                            }
                                        </ul>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </section>

        <section class="panel">
            <h2>Buscar</h2>
            <div class="stack">
                <form asp-action="Index" method="get" class="inline-form">
                    <input type="text" name="term" value="@Model.SearchTerm" placeholder="Banda ou musica" />
                    <button type="submit">Buscar</button>
                </form>

                @if (Model.SearchResult is null)
                {
                    <p class="muted-block">Sem resultado.</p>
                }
                else
                {
                    <div>
                        <h3>Bandas</h3>
                        @if (!Model.SearchResult.Artists.Any())
                        {
                            <p class="muted-block">Sem bandas.</p>
                        }
                        else
                        {
                            <div class="stack">
                                @foreach (var artist in Model.SearchResult.Artists)
                                {
                                    <div class="item-row">
                                        <strong>@artist.Name</strong>
                                        <form asp-action="FavoriteArtist" method="post" class="inline-form">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="ArtistId" value="@artist.Id" />
                                            <button type="submit">Favoritar</button>
                                        </form>
                                    </div>
                                }
                            </div>
                        }
                    </div>

                    <div>
                        <h3>Musicas</h3>
                        @if (!Model.SearchResult.Tracks.Any())
                        {
                            <p class="muted-block">Sem musicas.</p>
                        }
                        else
                        {
                            <div class="stack">
                                @foreach (var track in Model.SearchResult.Tracks)
                                {
                                    <div class="item-row">
                                        <div>
                                            <strong>@track.Title</strong>
                                            <div class="muted-block">@track.ArtistName</div>
                                        </div>
                                        <form asp-action="FavoriteTrack" method="post" class="inline-form">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="TrackId" value="@track.Id" />
                                            <button type="submit">Favoritar</button>
                                        </form>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }
            </div>
        </section>

        <section class="panel">
            <h2>Transacoes</h2>
            <div class="stack">
                <form asp-action="AuthorizeTransaction" method="post" class="stack">
                    @Html.AntiForgeryToken()
                    <select name="MerchantId">
                        @foreach (var merchant in Model.Merchants)
                        {
                            <option value="@merchant.Id">@merchant.Name (@merchant.Category)</option>
                        }
                    </select>
                    <input type="number" name="Amount" step="0.01" min="0.01" placeholder="Valor" />
                    <input type="datetime-local" name="RequestedAtUtc" />
                    <button type="submit">Autorizar</button>
                </form>

                <div>
                    <h3>Ultimas</h3>
                    <div class="scroll-table">
                        <table>
                            <thead>
                                <tr><th>Status</th><th>Valor</th><th>Motivo</th></tr>
                            </thead>
                            <tbody>
                            @foreach (var item in Model.Transactions)
                            {
                                <tr>
                                    <td>@item.Status</td>
                                    <td>@item.Amount.ToString("C")</td>
                                    <td>@item.Reason</td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </section>

        <section class="panel">
            <h2>Catalogo</h2>
            <div class="stack">
                <div>
                    <h3>Bandas</h3>
                    @if (!Model.Artists.Any())
                    {
                        <p class="muted-block">Sem bandas.</p>
                    }
                    else
                    {
                        <ul class="item-list">
                            @foreach (var artist in Model.Artists)
                            {
                                <li class="item-row">
                                    <span>@artist.Name</span>
                                    <span class="muted-block">@artist.Id</span>
                                </li>
                            }
                        </ul>
                    }
                </div>

                <div>
                    <h3>Albuns</h3>
                    @if (!Model.Albums.Any())
                    {
                        <p class="muted-block">Sem albuns.</p>
                    }
                    else
                    {
                        <div class="scroll-table">
                            <table>
                                <thead>
                                    <tr><th>Album</th><th>Banda</th><th>Ano</th></tr>
                                </thead>
                                <tbody>
                                @foreach (var album in Model.Albums)
                                {
                                    <tr>
                                        <td>@album.Title</td>
                                        <td>@album.ArtistName</td>
                                        <td>@album.ReleaseYear</td>
                                    </tr>
                                }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>

                <div>
                    <h3>Musicas</h3>
                    @if (!Model.Tracks.Any())
                    {
                        <p class="muted-block">Sem musicas.</p>
                    }
                    else
                    {
                        <ul class="item-list">
                            @foreach (var track in Model.Tracks)
                            {
                                <li class="item-row">
                                    <span>@track.Title - @track.ArtistName</span>
                                    <span class="muted-block">@track.Id</span>
                                </li>
                            }
                        </ul>
                    }
                </div>
            </div>
        </section>
    </div>
</div>
